{
  "name": "ritual",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/patch-capacitor-local-notifications.mjs",
    "patch:local-notifications": "node scripts/patch-capacitor-local-notifications.mjs",
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server:dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "cap:build": "npm run patch:local-notifications && vite build && npx cap sync",
    "cap:ios": "npm run patch:local-notifications && vite build && npx cap sync ios && npx cap open ios",
    "cap:android": "npm run patch:local-notifications && vite build && npx cap sync android && npx cap open android",
    "cap:sync": "npm run patch:local-notifications && npx cap sync"
  },
  "dependencies": {
    "@capacitor-firebase/messaging": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-health": "^8.9.3",
    "@e-is/capacitor-bluetooth-serial": "^6.0.3",
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.110.7",
    "@tailwindcss/vite": "^4.1.14",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
